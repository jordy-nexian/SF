# Database connection string (PostgreSQL)
# Example for Neon/Supabase:
# postgres://USER:PASSWORD@HOST:PORT/DB_NAME?sslmode=require
DATABASE_URL="postgres://user:password@host:5432/db_name?sslmode=require"

# Submission controls
# Soft limits to protect the relay; tune per-tenant in-app later.
SUBMISSION_MAX_BYTES="262144"     # 256 KiB
SUBMISSION_MAX_FIELDS="500"

# Upstash Redis (for distributed rate limiting)
# Get these from: https://console.upstash.com/redis
# If not set, rate limiting will be disabled (not recommended for production)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Cloudflare Turnstile (CAPTCHA alternative)
# Get these from: https://dash.cloudflare.com/turnstile
# If not set, CAPTCHA verification will be disabled
TURNSTILE_SECRET_KEY=""
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""

# Resend (for transactional emails: password reset, etc.)
# Get this from: https://resend.com/api-keys
# If not set in dev, emails are logged to console
RESEND_API_KEY=""
EMAIL_FROM="noreply@yourdomain.com"

# Logging
# Levels: trace, debug, info, warn, error, fatal
# Default: debug in dev, info in production
LOG_LEVEL=""

