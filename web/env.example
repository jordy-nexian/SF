# Database connection string (PostgreSQL)
# Example for Neon/Supabase:
# postgres://USER:PASSWORD@HOST:PORT/DB_NAME?sslmode=require
DATABASE_URL="postgres://user:password@host:5432/db_name?sslmode=require"

# Submission controls
# Soft limits to protect the relay; tune per-tenant in-app later.
SUBMISSION_MAX_BYTES="262144"     # 256 KiB
SUBMISSION_MAX_FIELDS="500"


