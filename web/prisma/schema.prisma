// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Multi-tenant SaaS data model — NO submission answers stored anywhere

enum Plan {
  free
  pro
  enterprise
}

enum BillingCycle {
  monthly
  annual
}

enum SubscriptionStatus {
  none
  active
  past_due
  canceled
  trialing
}

enum Role {
  owner
  admin
  viewer
}

enum FormStatus {
  draft
  live
  archived
}

enum SubmissionStatus {
  success
  error
}

enum AssignmentStatus {
  pending
  in_progress
  completed
}

model Tenant {
  id                     String   @id @default(cuid())
  name                   String
  plan                   Plan     @default(free)
  defaultN8nWebhookUrl   String?
  sharedSecret           String
  settings               Json?
  customDomain           String?  @unique  // Custom domain for forms
  customDomainVerified   Boolean  @default(false)
  
  // Portal branding
  portalTitle            String?  // Custom portal title
  portalLogoUrl          String?  // URL to logo image
  portalPrimaryColor     String?  // Hex color code e.g. #6366f1
  
  // Customer data integration
  customerWebhookUrl     String?  // Webhook URL for fetching customer forms from Quickbase
  
  // Subscription fields
  stripeCustomerId       String?  @unique
  stripeSubscriptionId   String?
  paypalSubscriptionId   String?
  billingCycle           BillingCycle @default(monthly)
  subscriptionStatus     SubscriptionStatus @default(none)
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean  @default(false)
  
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  users                  User[]
  forms                  Form[]
  themes                 Theme[]
  submissionEvents       SubmissionEvent[]
  htmlTemplates          HtmlTemplate[]
  endCustomers           EndCustomer[]
}

model User {
  id           String   @id @default(cuid())
  tenantId     String
  email        String   @unique
  passwordHash String?
  role         Role     @default(viewer)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  passwordResetTokens PasswordResetToken[]
}

model Form {
  id                      String      @id @default(cuid())
  tenantId                String
  name                    String
  publicId                String      @unique
  status                  FormStatus  @default(draft)
  primaryN8nWebhookUrl    String?
  backupWebhookUrl        String?     // Failover webhook
  webhookRouting          Json?       // Conditional webhook routing rules
  payloadTransform        Json?       // Payload transformation template
  currentVersionId        String?
  thankYouUrl             String?     // Redirect after submission
  thankYouMessage         String?     // Message if no redirect
  prefillWebhookUrl       String?     // Webhook URL to fetch prefill data on form load
  prefillFieldMappings    Json?       // Maps webhook label to form field name
  settings                Json?       // Additional form settings (IP allowlist, etc.)
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  templateId              String?

  tenant                  Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  versions                FormVersion[]
  currentVersion          FormVersion? @relation("CurrentFormVersion", fields: [currentVersionId], references: [id])
  submissionEvents        SubmissionEvent[]
  template                HtmlTemplate? @relation("FormTemplate", fields: [templateId], references: [id])
  assignments             FormAssignment[]

  @@index([tenantId])
}

model FormVersion {
  id             String   @id @default(cuid())
  formId         String
  versionNumber  Int
  schema         Json
  htmlContent    String?  @db.Text
  trafficWeight  Int      @default(0)  // A/B test weight (0 = not in test)
  createdAt      DateTime @default(now())

  form           Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  asCurrentOf    Form[]   @relation("CurrentFormVersion")

  @@unique([formId, versionNumber])
}

model Theme {
  id         String   @id @default(cuid())
  tenantId   String
  name       String
  config     Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model SubmissionEvent {
  id                String           @id @default(cuid())
  tenantId          String
  formId            String
  formVersion       Int
  submissionId      String           @unique
  status            SubmissionStatus
  httpCode          Int?
  durationMs        Int
  submittedAt       DateTime         @default(now())
  payloadSizeBytes  Int?
  fieldCount        Int?
  stepReached       Int?             // For drop-off analysis

  tenant            Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  form              Form             @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([tenantId, submittedAt])
  @@index([formId, submittedAt])
}

// Audit log for admin actions (no PII stored)
model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String
  action      String   // e.g., "form.created", "form.published", "version.created"
  resourceType String  // e.g., "form", "version", "theme"
  resourceId  String
  metadata    Json?    // Additional context (no PII)
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([resourceType, resourceId])
}

// Password reset tokens
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

// HTML Templates for pre-populated forms
model HtmlTemplate {
  id              String   @id @default(cuid())
  tenantId        String
  name            String
  htmlContent     String   @db.Text
  extractedTokens Json     // [{tokenId, label, position}]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  mappings        TokenMapping[]
  forms           Form[]   @relation("FormTemplate")

  @@index([tenantId])
}

// Token-to-payload field mappings
model TokenMapping {
  id          String       @id @default(cuid())
  templateId  String
  tokenId     String       // data-token-id UUID from HTML
  tokenLabel  String       // Human-readable label
  payloadKey  String       // Key in incoming JSON payload

  template    HtmlTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, tokenId])
  @@index([templateId])
}

// End customers who access the customer portal
model EndCustomer {
  id          String   @id @default(cuid())
  tenantId    String
  email       String
  name        String?
  externalId  String?  // External reference (e.g., from CRM)
  metadata    Json?    // Custom fields
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignments FormAssignment[]
  magicLinks  MagicLinkToken[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
}

// Form assignments to end customers
model FormAssignment {
  id                  String           @id @default(cuid())
  endCustomerId       String
  formId              String
  status              AssignmentStatus @default(pending)
  dueDate             DateTime?
  prefillData         Json?            // Optional cached prefill data
  lastReminderSentAt  DateTime?        // Track when last reminder was sent
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  completedAt         DateTime?

  endCustomer   EndCustomer @relation(fields: [endCustomerId], references: [id], onDelete: Cascade)
  form          Form        @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@unique([endCustomerId, formId])
  @@index([endCustomerId])
  @@index([formId])
}

// Magic link tokens for passwordless portal auth
model MagicLinkToken {
  id            String    @id @default(cuid())
  endCustomerId String
  token         String    @unique
  expiresAt     DateTime
  usedAt        DateTime?
  createdAt     DateTime  @default(now())

  endCustomer   EndCustomer @relation(fields: [endCustomerId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([endCustomerId])
}
