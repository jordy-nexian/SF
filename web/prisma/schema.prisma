// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Multi-tenant SaaS data model — NO submission answers stored anywhere

enum Plan {
  free
  pro
  enterprise
}

enum Role {
  owner
  admin
  viewer
}

enum FormStatus {
  draft
  live
  archived
}

enum SubmissionStatus {
  success
  error
}

model Tenant {
  id                     String   @id @default(cuid())
  name                   String
  plan                   Plan     @default(free)
  defaultN8nWebhookUrl   String?
  sharedSecret           String
  settings               Json?
  customDomain           String?  @unique  // Custom domain for forms
  customDomainVerified   Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  users                  User[]
  forms                  Form[]
  themes                 Theme[]
  submissionEvents       SubmissionEvent[]
}

model User {
  id           String   @id @default(cuid())
  tenantId     String
  email        String   @unique
  passwordHash String?
  role         Role     @default(viewer)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Form {
  id                      String      @id @default(cuid())
  tenantId                String
  name                    String
  publicId                String      @unique
  status                  FormStatus  @default(draft)
  primaryN8nWebhookUrl    String?
  backupWebhookUrl        String?     // Failover webhook
  webhookRouting          Json?       // Conditional webhook routing rules
  payloadTransform        Json?       // Payload transformation template
  currentVersionId        String?
  thankYouUrl             String?     // Redirect after submission
  thankYouMessage         String?     // Message if no redirect
  settings                Json?       // Additional form settings (IP allowlist, etc.)
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  tenant                  Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  versions                FormVersion[]
  currentVersion          FormVersion? @relation("CurrentFormVersion", fields: [currentVersionId], references: [id])
  submissionEvents        SubmissionEvent[]

  @@index([tenantId])
}

model FormVersion {
  id             String   @id @default(cuid())
  formId         String
  versionNumber  Int
  schema         Json
  trafficWeight  Int      @default(0)  // A/B test weight (0 = not in test)
  createdAt      DateTime @default(now())

  form           Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  asCurrentOf    Form[]   @relation("CurrentFormVersion")

  @@unique([formId, versionNumber])
}

model Theme {
  id         String   @id @default(cuid())
  tenantId   String
  name       String
  config     Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model SubmissionEvent {
  id                String           @id @default(cuid())
  tenantId          String
  formId            String
  formVersion       Int
  submissionId      String           @unique
  status            SubmissionStatus
  httpCode          Int?
  durationMs        Int
  submittedAt       DateTime         @default(now())
  payloadSizeBytes  Int?
  fieldCount        Int?
  stepReached       Int?             // For drop-off analysis

  tenant            Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  form              Form             @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([tenantId, submittedAt])
  @@index([formId, submittedAt])
}

// Audit log for admin actions (no PII stored)
model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String
  action      String   // e.g., "form.created", "form.published", "version.created"
  resourceType String  // e.g., "form", "version", "theme"
  resourceId  String
  metadata    Json?    // Additional context (no PII)
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([resourceType, resourceId])
}
