// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Multi-tenant SaaS data model — NO submission answers stored anywhere

enum Plan {
  free
  pro
  enterprise
}

enum Role {
  owner
  admin
  viewer
}

enum FormStatus {
  draft
  live
  archived
}

enum SubmissionStatus {
  success
  error
}

model Tenant {
  id                     String   @id @default(cuid())
  name                   String
  plan                   Plan     @default(free)
  defaultN8nWebhookUrl   String?
  sharedSecret           String
  settings               Json?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  users                  User[]
  forms                  Form[]
  themes                 Theme[]
  submissionEvents       SubmissionEvent[]
}

model User {
  id           String   @id @default(cuid())
  tenantId     String
  email        String   @unique
  passwordHash String?
  role         Role     @default(viewer)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Form {
  id                      String      @id @default(cuid())
  tenantId                String
  name                    String
  publicId                String      @unique
  status                  FormStatus  @default(draft)
  primaryN8nWebhookUrl    String?
  currentVersionId        String?
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  tenant                  Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  versions                FormVersion[]
  currentVersion          FormVersion? @relation("CurrentFormVersion", fields: [currentVersionId], references: [id])
  submissionEvents        SubmissionEvent[]

  @@index([tenantId])
}

model FormVersion {
  id             String   @id @default(cuid())
  formId         String
  versionNumber  Int
  schema         Json
  createdAt      DateTime @default(now())

  form           Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  asCurrentOf    Form[]   @relation("CurrentFormVersion")

  @@unique([formId, versionNumber])
}

model Theme {
  id         String   @id @default(cuid())
  tenantId   String
  name       String
  config     Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model SubmissionEvent {
  id                String           @id @default(cuid())
  tenantId          String
  formId            String
  formVersion       Int
  submissionId      String           @unique
  status            SubmissionStatus
  httpCode          Int?
  durationMs        Int
  submittedAt       DateTime         @default(now())
  payloadSizeBytes  Int?
  fieldCount        Int?

  tenant            Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  form              Form             @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([tenantId, submittedAt])
  @@index([formId, submittedAt])
}
